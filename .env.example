# Contoh konfigurasi environment untuk deployment
# Jangan commit file ini jika berisi data sensitif yang nyata.

# Port aplikasi
PORT=3000

# Koneksi MongoDB Atlas / MongoDB production
# Contoh: mongodb+srv://user:password@cluster0.mongodb.net/dbname?retryWrites=true&w=majority
MONGODB_URI=<your_production_mongodb_connection_string>

# JWT secret untuk token authentication
JWT_SECRET=<your_strong_jwt_secret>
JWT_EXPIRE=7d

# URL origin frontend yang diizinkan untuk CORS
CORS_ORIGIN=<https://your-frontend-domain.com>

# URL server untuk dokumentasi Swagger dan link lainnya
SERVER_URL=<https://your-api-domain.com>

# Environment mode (production / development)
NODE_ENV=production
